{
  "name": "agent-manager-template",
  "version": "0.1.0",
  "description": "Template reutilizable de Agent Manager con ejemplo de AI Agent",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "claudio": "./bin/claudio.cjs"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit/",
    "test:int": "vitest run tests/integration/",
    "test:e2e": "vitest run tests/e2e/",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "claudio": "tsx src/cli/claudio.ts"
  },
  "dependencies": {
    "fastify": "^5.8.5",
    "@fastify/cors": "^11.0.0",
    "openai": "^4.85.0",
    "zod": "^3.24.0",
    "dotenv": "^16.4.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.13.0",
    "vitest": "^3.1.0",
    "@vitest/coverage-v8": "^3.1.0",
    "eslint": "^9.22.0",
    "@eslint/js": "^9.22.0",
    "typescript-eslint": "^8.26.0",
    "prettier": "^3.5.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
