{
  "name": "@matiasscalbi/auto-audit-loop",
  "version": "1.0.0",
  "description": "Sistema de auditoría automática con agentes expertos para cualquier proyecto. Se activa con cada edición de código, ejecuta gates de calidad y genera reportes HTML.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "auto-audit": "dist/cli/bin.js",
    "auto-audit-init": "dist/cli/init.js"
  },
  "files": [
    "dist/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "audit",
    "security",
    "typescript",
    "testing",
    "ci",
    "cd",
    "quality",
    "agents",
    "claude",
    "automation",
    "hooks"
  ],
  "author": "Matias Scalbi <matias@scalbi.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/matiasscalbi/auto-audit-loop.git"
  },
  "bugs": {
    "url": "https://github.com/matiasscalbi/auto-audit-loop/issues"
  },
  "homepage": "https://github.com/matiasscalbi/auto-audit-loop#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "vitest": ">=1.0.0",
    "typescript": ">=4.9.0"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  }
}
